# Copy to .env and fill in your keys.
# DO NOT commit the filled-in .env — it is gitignored on purpose.

# ── Required ───────────────────────────────────────────────────────────
# Hair analysis (GPT-4o vision)
OPENAI_API_KEY=your_openai_api_key_here

# Image previews + video (FAL gateway to Nano Banana + Kling)
FAL_API_KEY=your_fal_api_key_here

# ── Optional ───────────────────────────────────────────────────────────
# Persist each analysis + generated images to Supabase. App runs fine
# without these — leave blank to disable persistence.
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=
# SUPABASE_BUCKET=halo-assets

# Override default models if you want
# HAIR_MODEL=gpt-4o
# VIDEO_MODEL=fal-ai/kling-video/v1.6/standard/image-to-video
# PORT=8765
