# Doc Dashboard — copy to .env, fill in, keep out of git.

# Flask
DASHBOARD_PORT=8900
DASHBOARD_HOST=127.0.0.1
SHARED_SECRET=change-me-please

# Optional shared cloud keys (only used by cloud-fallback toggles)
OPENAI_API_KEY=
FAL_API_KEY=
ANTHROPIC_API_KEY=

# Local AI stack
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# Qdrant (your MYN Cockpit stack)
QDRANT_URL=http://localhost:6333
QDRANT_DEFAULT_COLLECTION=dashboard_docs

# AI Video Studio proxy
STUDIO_URL=http://localhost:8780

# HALO proxy
HALO_URL=http://localhost:8765

# Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
